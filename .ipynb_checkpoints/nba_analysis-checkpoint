    "# Query 2: Which teams have the most efficient offenses?\n",
    "# (Best points per game with best shooting %)\n",
    "query = \"\"\"\n",
    "SELECT \n",
    "    TEAM_ABBREVIATION,\n",
    "    COUNT(PLAYER_NAME) AS roster_players,\n",
    "    ROUND(AVG(PTS), 1) AS avg_pts_per_player,\n",
    "    ROUND(AVG(FG_PCT) * 100, 1) AS avg_fg_pct,\n",
    "    ROUND(AVG(FG3_PCT) * 100, 1) AS avg_3pt_pct,\n",
    "    ROUND(AVG(TOV), 2) AS avg_turnovers\n",
    "FROM player_stats\n",
    "WHERE GP >= 20 AND MIN >= 10\n",
    "GROUP BY TEAM_ABBREVIATION\n",
    "ORDER BY avg_pts_per_player DESC\n",
    "LIMIT 10\n",
    "\"\"\"\n",
    "\n",
    "team_efficiency = pd.read_sql_query(query, conn)\n",
    "print(\"Top 10 Most Efficient Team Offenses - 2024-25\")\n",
    "print(team_efficiency.to_string(index=False))"
   ]
