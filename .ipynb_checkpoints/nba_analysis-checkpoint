    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Top 15 scorers for the chart\n",
    "query = \"\"\"\n",
    "SELECT PLAYER_NAME, TEAM_ABBREVIATION, PTS, FG_PCT\n",
    "FROM player_stats\n",
    "WHERE GP >= 20\n",
    "ORDER BY PTS DESC\n",
    "LIMIT 15\n",
    "\"\"\"\n",
    "top15 = pd.read_sql_query(query, conn)\n",
    "\n",
    "# Plot\n",
    "fig, ax = plt.subplots(figsize=(12, 7))\n",
    "colors = sns.color_palette(\"viridis\", len(top15))\n",
    "bars = ax.barh(top15['PLAYER_NAME'], top15['PTS'], color=colors)\n",
    "\n",
    "# Add value labels on each bar\n",
    "for bar, val in zip(bars, top15['PTS']):\n",
    "    ax.text(bar.get_width() + 0.1, bar.get_y() + bar.get_height()/2,\n",
    "            f'{val:.1f}', va='center', fontsize=10)\n",
    "\n",
    "ax.set_xlabel('Points Per Game', fontsize=12)\n",
    "ax.set_title('NBA Top 15 Scorers — 2024-25 Season', fontsize=14, fontweight='bold')\n",
    "ax.invert_yaxis()\n",
    "plt.tight_layout()\n",
    "plt.savefig('top_scorers.png', dpi=150)\n",
    "plt.show()"
   ]
