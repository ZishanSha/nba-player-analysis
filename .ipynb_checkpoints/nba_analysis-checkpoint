    "# Query 1: Top 10 scorers this season (minimum 20 games played)\n",
    "query = \"\"\"\n",
    "SELECT \n",
    "    PLAYER_NAME,\n",
    "    TEAM_ABBREVIATION,\n",
    "    GP,\n",
    "    ROUND(PTS, 1) AS points_per_game,\n",
    "    ROUND(FG_PCT * 100, 1) AS fg_pct,\n",
    "    ROUND(MIN, 1) AS minutes\n",
    "FROM player_stats\n",
    "WHERE GP >= 20\n",
    "ORDER BY PTS DESC\n",
    "LIMIT 10\n",
    "\"\"\"\n",
    "\n",
    "top_scorers = pd.read_sql_query(query, conn)\n",
    "print(\"Top 10 Scorers - 2024-25 NBA Season\")\n",
    "print(top_scorers.to_string(index=False))"
